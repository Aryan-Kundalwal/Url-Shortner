<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener Dashboard</title>


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body{
        background:#f5f7fb;
    }

    .main-card{
        max-width:900px;
        margin:auto;
        margin-top:40px;
    }

    .qr-btn {
    width: 220px;
    height: 45px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

    .qr-image{
        border:1px solid #ddd;
        padding:10px;
        border-radius:10px;
        background:white;
    }

    .table-container{
        margin-top:30px;
    }

   .table-scroll {
    max-height: 300px;
    overflow-y: auto;
    border: 1px solid #eee;
}
</style>


</head>

<body>

<nav class="navbar navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand">🚀 URL Shortener</a>
    </div>
</nav>

<div class="container">

<div class="card shadow main-card">
    <div class="card-body">

        <h2 class="text-center mb-4">
            Create Short URL
        </h2>

        <form method="POST" action="/url">

            <div class="input-group">

                <input
                    type="text"
                    class="form-control"
                    name="url"
                    placeholder="https://example.com"
                    required
                >

                <button
                    class="btn btn-primary"
                    type="submit"
                >
                    Generate
                </button>

            </div>

        </form>

        <% if (locals.id) { %>

            <hr>

            <h4>Generated URL</h4>

            <div class="input-group mb-3">

                <input
                    type="text"
                    id="shortUrl"
                    class="form-control"
                    value="http://localhost:8001/url/<%= id %>"
                    readonly
                >

                <button
                    class="btn btn-success"
                    onclick="copyURL()"
                >
                    Copy
                </button>

            </div>

            <% if(locals.qrCode){ %>

                <div class="text-center">

                    <img
                        src="<%= qrCode %>"
                        width="220"
                        class="qr-image"
                    >

                    <br><br>

              <div class="qr-actions">

    <a href="<%= qrCode %>" download="qrcode.png" class="btn btn-outline-primary qr-btn">
        Download QR
    </a>

    <button class="btn btn-success qr-btn" onclick="shareQR()">
        Share QR Code
    </button>

</div>

                </div>

            <% } %>

        <% } %>

    </div>
</div>

<% if(locals.urls){ %>

<div class="table-container">

    <div class="card shadow">

       <div class="card-body">

    <h3>Your URLs</h3>

    <div class="<%= urls.length > 5 ? 'table-scroll' : '' %>">

            

            <table class="table table-striped">

                <thead>

                <tr>
                    <th>#</th>
                    <th>Short ID</th>
                    <th>Original URL</th>
                    <th>Clicks</th>
                     <th>QR Code</th>
                </tr>

                </thead>

                <tbody>

                <% urls.forEach((url,index)=> { %>

                    <tr>

                        <td>
                            <%= index + 1 %>
                        </td>

                        <td>
                            <a href="/url/<%= url.shortId %>">
                                <%= url.shortId %>
                            </a>
                        </td>

                        <td>
                            <%= url.redirectURL %>
                        </td>

                        <td>
                            <%= url.visitHistory.length %>
                        </td>
                          <td>
        <img 
          src="<%= url.qrCode %>" 
          width="80" 
          class="border rounded"
        />

        <br />

        <a 
          href="<%= url.qrCode %>" 
          download="qr-<%= url.shortId %>.png"
          class="btn btn-sm btn-outline-primary mt-1"
        >
          Download
        </a>
      </td>
                    </tr>

                <% }) %>

                </tbody>

            </table>
            </div>

        </div>

    </div>

</div>

<% } %>


</div>

<script>


async function shareQR() {
    const qrImage = "<%= qrCode %>";
    const shortUrl = document.getElementById("shortUrl").value;

    const shareData = {
        title: "My Short URL",
        text: "Check this QR Code + Short URL",
        url: shortUrl
    };

    if (navigator.share) {
        try {
            await navigator.share(shareData);
        } catch (err) {
            console.log("Share cancelled", err);
        }
    } else {
        
        navigator.clipboard.writeText(shortUrl);
        alert("Link copied! Share it manually.");
    }
}

function copyURL(){

    const copyText =
        document.getElementById("shortUrl");

    navigator.clipboard.writeText(
        copyText.value
    );

    alert("URL Copied!");
}

</script>

</body>
</html>
