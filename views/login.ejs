<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-slate-900 via-indigo-900 to-slate-900 min-h-screen flex items-center justify-center">

  <!-- Card -->
  <div class="w-[380px] bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl rounded-2xl p-8">

    <!-- Title -->
    <h1 class="text-3xl font-bold text-center text-white mb-6">
      Welcome Back
    </h1>

    <p class="text-center text-gray-300 text-sm mb-6">
      Login to continue to your dashboard
    </p>

    <!-- Form -->
    <form action="/user/login" method="POST" class="space-y-4">

      <!-- Email -->
      <div>
        <label class="text-sm text-gray-300">Email</label>
        <input
          type="email"
          name="email"
          placeholder="Enter your email"
          class="w-full mt-1 p-3 rounded-lg bg-white/10 text-white border border-white/20 focus:outline-none focus:ring-2 focus:ring-indigo-500"
          required
        />
      </div>

      <!-- Password -->
      <div>
        <label class="text-sm text-gray-300">Password</label>
        <input
          type="password"
          name="password"
          placeholder="Enter your password"
          class="w-full mt-1 p-3 rounded-lg bg-white/10 text-white border border-white/20 focus:outline-none focus:ring-2 focus:ring-indigo-500"
          required
        />
      </div>

      <!-- Button -->
      <button
        type="submit"
        class="w-full bg-indigo-600 hover:bg-indigo-700 transition-all text-white py-3 rounded-lg font-semibold shadow-lg"
      >
        Login
      </button>
    </form>

    <!-- Divider -->
    <div class="my-5 border-t border-white/10"></div>

    <!-- Signup Link -->
    <p class="text-center text-sm text-gray-300">
      Don't have an account?
      <a href="/signup" class="text-indigo-400 hover:underline font-medium">
        Sign up
      </a>
    </p>

  </div>

</body>
</html>